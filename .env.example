# Copy to .env and fill in keys. .env is git-ignored and excluded from the
# Docker build context via .dockerignore — secrets are injected at runtime only.

ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
PINECONE_API_KEY=""
PINECONE_INDEX_NAME_V2="civ6-bbg-v2"

# Password gate for the Streamlit UI
APP_PASSWORD=""

# Optional outside Docker Compose: when unset, the app falls back to an
# in-memory MemorySaver checkpointer. Inside Compose, DATABASE_URL is set in
# docker-compose.yml's environment block instead.
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
